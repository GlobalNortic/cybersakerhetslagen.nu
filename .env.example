# Server-side only (set in Vercel → Project → Settings → Environment Variables).
# Never prefix with VITE_ — these must not be exposed to the browser.

# Brevo Transactional Email API key (https://app.brevo.com/settings/keys/api)
BREVO_API_KEY=

# Internal recipient that receives lead notification emails
LEAD_TO_EMAIL=

# Internal recipient that receives partner inquiry emails
PARTNER_TO_EMAIL=
